{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "adf-healthcare-reporting"
        },
        "ls_adls_healthcare_reporting_dl_accountKey": {
            "type": "secureString",
            "metadata": "Secure string for 'accountKey' of 'ls_adls_healthcare_reporting_dl'"
        },
        "ls_sql_healthcare_db_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'ls_sql_healthcare_db'"
        },
        "ls_adls_healthcare_reporting_dl_properties_typeProperties_url": {
            "type": "string",
            "defaultValue": "https://dlhealthcarereporting.dfs.core.windows.net/"
        },
        "ls_http_healthcare_reporting_properties_typeProperties_url": {
            "type": "string",
            "defaultValue": "https://raw.githubusercontent.com/"
        },
        "ls_sql_healthcare_db_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "healthcare-reporting-srv.database.windows.net"
        },
        "ls_sql_healthcare_db_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "healthcare-db"
        },
        "ls_sql_healthcare_db_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "triasamunshi"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "adf-healthcare-reporting_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "ls_adls_healthcare_reporting_dl_accountKey": {
                        "value": "[parameters('ls_adls_healthcare_reporting_dl_accountKey')]"
                    },
                    "ls_sql_healthcare_db_password": {
                        "value": "[parameters('ls_sql_healthcare_db_password')]"
                    },
                    "ls_adls_healthcare_reporting_dl_properties_typeProperties_url": {
                        "value": "[parameters('ls_adls_healthcare_reporting_dl_properties_typeProperties_url')]"
                    },
                    "ls_http_healthcare_reporting_properties_typeProperties_url": {
                        "value": "[parameters('ls_http_healthcare_reporting_properties_typeProperties_url')]"
                    },
                    "ls_sql_healthcare_db_properties_typeProperties_server": {
                        "value": "[parameters('ls_sql_healthcare_db_properties_typeProperties_server')]"
                    },
                    "ls_sql_healthcare_db_properties_typeProperties_database": {
                        "value": "[parameters('ls_sql_healthcare_db_properties_typeProperties_database')]"
                    },
                    "ls_sql_healthcare_db_properties_typeProperties_userName": {
                        "value": "[parameters('ls_sql_healthcare_db_properties_typeProperties_userName')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}